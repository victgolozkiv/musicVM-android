<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pure_black"
    android:clickable="true"
    android:focusable="true">

    <View
        android:id="@+id/bgGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/player_bg_gradient" />

    <ImageButton
        android:id="@+id/btnDismiss"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_white" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reproduciendo"
        android:textColor="@color/text_white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        app:layout_constraintBottom_toBottomOf="@id/btnDismiss"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnDismiss" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDisc"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="60dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="250dp"
        app:cardElevation="30dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnDismiss"
        app:strokeColor="#33FFFFFF"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/imgFullPlayerArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:transitionName="cover_transition"
            tools:src="@android:drawable/ic_menu_report_image" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvFullPlayerTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="40dp"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:textColor="@color/text_white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardDisc"
        tools:text="Song Title" />

    <TextView
        android:id="@+id/tvFullPlayerArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/purple_primary"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="@id/tvFullPlayerTitle"
        app:layout_constraintStart_toStartOf="@id/tvFullPlayerTitle"
        app:layout_constraintTop_toBottomOf="@id/tvFullPlayerTitle"
        tools:text="Artist Name" />

    <TextView
        android:id="@+id/tvCurrentLyric"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:textColor="@color/text_white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFullPlayerArtist"
        app:layout_constraintBottom_toTopOf="@id/playerSlider"
        tools:text="♪ Singing lyrics here ♪" />

    <com.google.android.material.slider.Slider
        android:id="@+id/playerSlider"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFullPlayerArtist"
        app:thumbColor="@color/purple_primary"
        app:thumbRadius="6dp"
        app:thumbElevation="4dp"
        app:trackColorActive="@color/purple_primary"
        app:trackColorInactive="#26FFFFFF"
        app:haloColor="#4D6200EE" />

    <TextView
        android:id="@+id/tvCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="0:00"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/playerSlider"
        app:layout_constraintTop_toBottomOf="@id/playerSlider" />

    <TextView
        android:id="@+id/tvTotalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="0:00"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/playerSlider"
        app:layout_constraintTop_toBottomOf="@id/playerSlider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvCurrentTime">

        <ImageButton
            android:id="@+id/btnPrev"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/circle_background"
            android:backgroundTint="#4DFFFFFF"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_prev_mod"
            app:tint="@color/pure_black" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnFullPlayPause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            app:backgroundTint="@color/text_white"
            app:fabCustomSize="85dp"
            app:maxImageSize="45dp"
            app:elevation="12dp"
            app:srcCompat="@drawable/ic_play_mod"
            app:tint="@color/pure_black"
            app:borderWidth="0dp"/>

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/circle_background"
            android:backgroundTint="#4DFFFFFF"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_next_mod"
            app:tint="@color/pure_black" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
