<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pure_black">

    <TextView
        android:id="@+id/tvDownloadsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="32dp"
        android:text="Descargas"
        android:textColor="@color/text_white"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btnPhysical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDownloadsTitle">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPhysical"
            style="?attr/materialButtonOutlinedStyle"
            android:textColor="@color/text_white"
            app:strokeColor="@color/text_grey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Archivos Locales" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCache"
            style="?attr/materialButtonOutlinedStyle"
            android:textColor="@color/text_white"
            app:strokeColor="@color/text_grey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☁️ Caché Remoto" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/downloadsRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toggleGroup"
        tools:listitem="@layout/item_song" />

    <TextView
        android:id="@+id/tvNoDownloads"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No hay canciones descargadas"
        android:textColor="@color/text_grey"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
